# Local defaults are safe for development. Copy this file to .env.

# App/auth
SECRET_KEY=change-me-for-local-dev
# Enables /auth/dev-token only when set to true.
DEV_AUTO_LOGIN=false

# Python import path used by Render/CI direct uvicorn commands.
PYTHONPATH=src

# OCR backend: "tesseract" (default), "vision" (Google), "vision_field", "claude", or "reducto"
OCR_BACKEND=tesseract

# Google Cloud Vision — only needed if OCR_BACKEND=vision
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Anthropic Claude — needed for OCR_BACKEND=claude and optional review/fraud analysis paths
ANTHROPIC_API_KEY=

# Reducto — only needed if OCR_BACKEND=reducto
REDUCTO_API_KEY=

# Database
DATABASE_URL=sqlite:///./petition_verifier.db
# For PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/petition_verifier

# Classic CLI voter-roll path. Can also be passed with --voter-roll.
VOTER_ROLL_CSV=tests/fixtures/voter_roll.csv

# Matching thresholds
THRESHOLD_APPROVE=85
THRESHOLD_REVIEW=70

# Optional review extraction ensemble path.
EXTRACTION_USE_ENSEMBLE=false

# Tesseract binary path (if not in PATH)
# TESSERACT_CMD=/usr/local/bin/tesseract
