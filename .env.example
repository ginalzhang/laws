# OCR backend: "tesseract" (default), "vision" (Google), or "reducto"
OCR_BACKEND=tesseract

# Google Cloud Vision — only needed if OCR_BACKEND=vision
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Reducto — only needed if OCR_BACKEND=reducto
REDUCTO_API_KEY=

# Database
DATABASE_URL=sqlite:///./petition_verifier.db
# For PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/petition_verifier

# Auth
# Required for login/JWTs outside explicit development auto-login mode.
SECRET_KEY=replace-with-a-long-random-secret

# Development-only shortcuts for local demos:
# - seeds local demo accounts at startup
# - enables /auth/login-by-name, /auth/active-users, /auth/dev-token, /auth/scan-login
DEV_AUTO_LOGIN=false
# SCAN_LOGIN_PASSWORD=

# Optional production bootstrap. Creates this boss account once if it does not
# already exist; it never resets an existing password.
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=

# Matching thresholds
THRESHOLD_APPROVE=85
THRESHOLD_REVIEW=70

# Tesseract binary path (if not in PATH)
# TESSERACT_CMD=/usr/local/bin/tesseract
